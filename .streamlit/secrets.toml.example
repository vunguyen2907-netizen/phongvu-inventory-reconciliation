# Copy nội dung này vào .streamlit/secrets.toml khi chạy local.
# Khi deploy Streamlit Community Cloud, thêm hai biến này ở Advanced settings > Secrets.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-secret-or-service-role-key"
# Khóa public dành cho SPA. Không dùng SUPABASE_KEY ở đây.
SUPABASE_PUBLISHABLE_KEY = "your-sb-publishable-key"
